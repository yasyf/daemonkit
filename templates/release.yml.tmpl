# Caller for yasyf/homebrew-tap's artifact-only release-app.yml, rendered by
# repo-bootstrap's daemonkit layer. The reusable workflow stages a verified
# artifact; this caller alone owns the draft and final GitHub Release.
name: release

on:
  push:
    tags:
      - "v*"

jobs:
  version:
    runs-on: ubuntu-latest
    outputs:
      marketing: ${{ steps.derive.outputs.marketing }}
      stable: ${{ steps.derive.outputs.stable }}
    steps:
      - id: derive
        shell: bash
        # release-app.yml requires bare MAJOR.MINOR.PATCH; the tag carries a v
        # prefix and, on rc tags, a prerelease suffix.
        run: |
          set -euo pipefail
          v="${GITHUB_REF_NAME#v}"
          echo "marketing=${v%%-*}" >> "$GITHUB_OUTPUT"
          case "$GITHUB_REF_NAME" in
            *-*) echo "stable=false" >> "$GITHUB_OUTPUT" ;;
            *) echo "stable=true" >> "$GITHUB_OUTPUT" ;;
          esac

  release:
    needs: version
    permissions:
      contents: read
    uses: yasyf/homebrew-tap/.github/workflows/release-app.yml@83ee384b1d4fe25a8e4aa7258bb76d55e1593735
    with:
      app_name: __APP_NAME__
      asset_name: __CASK_TOKEN__
      project_dir: .
      scheme: __APP_NAME__
      bundle_id: __BUNDLE_ID__
      marketing_version: ${{ needs.version.outputs.marketing }}
      # The widget appex ships by default with project.yml.tmpl. appexes is a
      # newline-separated list; app_groups and profile_names take newline-
      # separated bundle=value pairs, and app_groups requires profile_names so
      # every claim is profile-authorized before signing.
      appexes: Contents/PlugIns/__APP_NAME__Widget.appex
      app_groups: |
        __BUNDLE_ID__=__APP_GROUP__
        __BUNDLE_ID__.widget=__APP_GROUP__
      profile_names: |
        __BUNDLE_ID__=__PROFILE_APP__
        __BUNDLE_ID__.widget=__PROFILE_WIDGET__
    secrets:
      MACOS_SIGN_P12: ${{ secrets.MACOS_SIGN_P12 }}
      MACOS_SIGN_PASSWORD: ${{ secrets.MACOS_SIGN_PASSWORD }}
      MACOS_NOTARY_KEY: ${{ secrets.MACOS_NOTARY_KEY }}
      MACOS_NOTARY_KEY_ID: ${{ secrets.MACOS_NOTARY_KEY_ID }}
      MACOS_NOTARY_ISSUER_ID: ${{ secrets.MACOS_NOTARY_ISSUER_ID }}

  publish:
    needs: [version, release]
    if: needs.release.outputs.changed == 'true'
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v7

      - name: Download the verified application artifact
        uses: actions/download-artifact@v8
        with:
          name: ${{ needs.release.outputs.artifact_name }}
          path: dist

      - name: Assert the verified application artifact contract
        shell: bash
        env:
          ASSET_FILENAME: ${{ needs.release.outputs.asset_filename }}
          ASSET_URL: ${{ needs.release.outputs.asset_url }}
          ASSET_SHA256: ${{ needs.release.outputs.sha256 }}
          CASK_TOKEN: __CASK_TOKEN__
        run: |
          set -euo pipefail
          expected="${CASK_TOKEN}-${GITHUB_REF_NAME}-darwin.zip"
          [ "$ASSET_FILENAME" = "$expected" ] \
            || { echo "::error::verified asset filename '$ASSET_FILENAME' != '$expected'"; exit 1; }
          [ -n "$ASSET_URL" ] \
            || { echo "::error::release-app returned an empty asset URL"; exit 1; }
          [[ "$ASSET_SHA256" =~ ^[0-9a-f]{64}$ ]] \
            || { echo "::error::release-app returned an invalid SHA-256"; exit 1; }
          [ -f "dist/$ASSET_FILENAME" ] && [ -f "dist/$ASSET_FILENAME.sha256" ] \
            || { echo "::error::staged application artifact is incomplete"; exit 1; }
          count="$(find dist -maxdepth 1 -type f | wc -l | tr -d ' ')"
          [ "$count" -eq 2 ] \
            || { echo "::error::staged application artifact has $count files, want 2"; exit 1; }
          (cd dist && shasum -a 256 -c "$ASSET_FILENAME.sha256")
          actual="$(shasum -a 256 "dist/$ASSET_FILENAME" | awk '{print $1}')"
          [ "$actual" = "$ASSET_SHA256" ] \
            || { echo "::error::staged application SHA changed after verification"; exit 1; }

      - name: Record the exact release asset manifest
        shell: bash
        env:
          ASSET_FILENAME: ${{ needs.release.outputs.asset_filename }}
        run: |
          set -euo pipefail
          printf '%s\n' "dist/$ASSET_FILENAME" "dist/$ASSET_FILENAME.sha256" \
            > "$RUNNER_TEMP/app-release-assets"

      - name: Stage and verify the complete draft release
        id: draft
        uses: yasyf/homebrew-tap/.github/actions/stage-draft-release@e4c3108e693681df1a3c666bae80e890bc44cf3e
        with:
          token: ${{ github.token }}
          tag: ${{ github.ref_name }}
          manifest: ${{ runner.temp }}/app-release-assets
          title: ${{ github.ref_name }}
          prerelease: ${{ contains(github.ref_name, '-') }}

      - name: Guard cask registry name and version
        if: needs.version.outputs.stable == 'true'
        shell: bash
        env:
          CASK_TOKEN: __CASK_TOKEN__
          VERSION: ${{ github.ref_name }}
        run: |
          set -euo pipefail
          # shellcheck disable=SC2153 # VERSION is supplied through the step env.
          version="${VERSION#v}"
          tmp="$(mktemp -d)"

          fetch() {
            url="$1"
            output="$2"
            if ! code="$(curl --connect-timeout 15 --max-time 45 -sS -o "$output" -w '%{http_code}' "$url")"; then
              echo "::error::registry guard could not reach $url; refusing to release blind"
              exit 1
            fi
            case "$code" in
              200|404) printf '%s' "$code" ;;
              *) echo "::error::registry guard got HTTP $code from $url; refusing to release blind"; exit 1 ;;
            esac
          }

          formula_url="https://raw.githubusercontent.com/yasyf/homebrew-tap/main/Formula/${CASK_TOKEN}.rb"
          formula_code="$(fetch "$formula_url" "$tmp/formula.rb")"
          if [ "$formula_code" = "200" ]; then
            echo "::error::Formula/${CASK_TOKEN}.rb already exists; a same-named cask would make brew install ambiguous"
            exit 1
          fi

          cask_url="https://raw.githubusercontent.com/yasyf/homebrew-tap/main/Casks/${CASK_TOKEN}.rb"
          cask_code="$(fetch "$cask_url" "$tmp/cask.rb")"
          if [ "$cask_code" = "404" ]; then
            exit 0
          fi
          grep -Eq "^[[:space:]]*cask[[:space:]]+\"${CASK_TOKEN}\"[[:space:]]+do" "$tmp/cask.rb" \
            || { echo "::error::the registered Casks/${CASK_TOKEN}.rb declares a different cask name"; exit 1; }
          current="$(sed -n 's/^[[:space:]]*version[[:space:]]*\"\([0-9][0-9.]*\)\".*/\1/p' "$tmp/cask.rb" | sed -n '1p')"
          [ -n "$current" ] \
            || { echo "::error::could not parse the registered version for $CASK_TOKEN"; exit 1; }
          first="$(printf '%s\n%s\n' "$current" "$version" | sort -V | sed -n '1p')"
          if [ "$first" = "$version" ] && [ "$current" != "$version" ]; then
            echo "::error::release version $version is older than registered cask version $current"
            exit 1
          fi

      - name: Require a full-application cask template
        if: needs.version.outputs.stable == 'true'
        shell: bash
        run: |
          set -euo pipefail
          grep -Eq '^[[:space:]]*app[[:space:]]+' templates/cask.rb.tmpl \
            || { echo "::error::cask template must install the full .app with an app stanza"; exit 1; }
          if grep -Eq '^[[:space:]]*binary[[:space:]]+' templates/cask.rb.tmpl; then
            echo "::error::cask template must not install this application as a bare binary"
            exit 1
          fi

      - name: Render the cask
        if: needs.version.outputs.stable == 'true'
        uses: yasyf/homebrew-tap/.github/actions/render-formula@19c3d5013032ad9c88f9a8f1170d1f366c19b8d9
        with:
          template: templates/cask.rb.tmpl
          output: Casks/__CASK_TOKEN__.rb
          version: ${{ needs.version.outputs.marketing }}
          substitutions: |
            __ASSET_URL__=${{ needs.release.outputs.asset_url }}
            __SHA_APP__=${{ needs.release.outputs.sha256 }}

      - name: Test the rendered cask locally
        if: needs.version.outputs.stable == 'true'
        shell: bash
        env:
          ASSET_SHA256: ${{ needs.release.outputs.sha256 }}
          ASSET_URL: ${{ needs.release.outputs.asset_url }}
          VERSION: ${{ needs.version.outputs.marketing }}
        run: |
          set -euo pipefail
          cask=tap-staging/Casks/__CASK_TOKEN__.rb
          ruby -c "$cask"
          grep -Fq "version \"$VERSION\"" "$cask"
          grep -Fq "sha256 \"$ASSET_SHA256\"" "$cask"
          grep -Fq "url \"$ASSET_URL\"" "$cask"
          grep -Eq '^[[:space:]]*app[[:space:]]+' "$cask"

      - name: Publish the verified release
        uses: yasyf/homebrew-tap/.github/actions/publish-draft-release@54e3e194bda69896894a82c17fcdb2822beefab5
        with:
          token: ${{ github.token }}
          release-id: ${{ steps.draft.outputs['release-id'] }}
          tag: ${{ github.ref_name }}
          manifest: ${{ runner.temp }}/app-release-assets
          prerelease: ${{ contains(github.ref_name, '-') }}
          make-latest: ${{ needs.version.outputs.stable == 'true' }}

      - name: Verify the public release asset
        shell: bash
        env:
          ASSET_FILENAME: ${{ needs.release.outputs.asset_filename }}
          ASSET_SHA256: ${{ needs.release.outputs.sha256 }}
          ASSET_URL: ${{ needs.release.outputs.asset_url }}
        run: |
          set -euo pipefail
          curl --fail --location --retry 4 --output "$RUNNER_TEMP/$ASSET_FILENAME" "$ASSET_URL"
          actual="$(shasum -a 256 "$RUNNER_TEMP/$ASSET_FILENAME" | awk '{print $1}')"
          [ "$actual" = "$ASSET_SHA256" ] \
            || { echo "::error::public release asset SHA differs from the verified artifact"; exit 1; }

      - name: Publish the cask to the tap
        if: needs.version.outputs.stable == 'true'
        uses: yasyf/homebrew-tap/.github/actions/publish@9ca67392d45d66b6ae01e262383c8f3138d56f5e
        with:
          token: ${{ secrets.HOMEBREW_TAP_TOKEN }}
          dir: tap-staging
          message: "__CASK_TOKEN__ ${{ github.ref_name }}"

      - name: Verify the published cask and asset
        if: needs.version.outputs.stable == 'true'
        shell: bash
        env:
          ASSET_SHA256: ${{ needs.release.outputs.sha256 }}
          ASSET_URL: ${{ needs.release.outputs.asset_url }}
        run: |
          set -euo pipefail
          published="$RUNNER_TEMP/published-cask.rb"
          curl --fail --location --retry 4 \
            --output "$published" \
            "https://raw.githubusercontent.com/yasyf/homebrew-tap/main/Casks/__CASK_TOKEN__.rb"
          cmp tap-staging/Casks/__CASK_TOKEN__.rb "$published"
          curl --fail --location --retry 4 --output "$RUNNER_TEMP/public-app.zip" "$ASSET_URL"
          actual="$(shasum -a 256 "$RUNNER_TEMP/public-app.zip" | awk '{print $1}')"
          [ "$actual" = "$ASSET_SHA256" ] \
            || { echo "::error::published cask asset is not publicly retrievable and exact"; exit 1; }

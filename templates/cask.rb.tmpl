# Homebrew cask for a daemonkit signed helper app (__APP_NAME__.app).
#
# The app is Developer ID signed, notarized, and stapled, so Gatekeeper
# validates it offline; the postflight strips Homebrew's download quarantine so
# the first launch is silent. Generalized from cc-pool's cc-pool-status.rb.tmpl
# and fusekit's fusekit-holder.rb.tmpl.
#
#   brew install --cask __GH_OWNER__/tap/__CASK_TOKEN__
#
# GENERATED by the release workflow (render-formula) — do not hand-edit; change
# templates/cask.rb.tmpl instead. The version and app sha256 are filled per
# release; the other placeholders are filled once at scaffold time.
cask "__CASK_TOKEN__" do
  version "__VERSION__"
  sha256 "__SHA_APP__" # app

  url "https://github.com/__GH_OWNER__/__GH_REPO__/releases/download/v#{version}/__CASK_TOKEN__-v#{version}-darwin.zip"
  name "__DISPLAY_NAME__"
  desc "__DESC__"
  homepage "https://github.com/__GH_OWNER__/__GH_REPO__"

  depends_on macos: :__MACOS_MIN__ # parsed with a ">=" comparator

  # A full .app bundle, never a bare `binary`: only a bundle staples its
  # notarization ticket and keeps a stable, bundle-keyed TCC/Keychain identity
  # across upgrades (a bare Mach-O can't staple and gets path-keyed TCC). The
  # installed app is LSUIElement (no Dock icon) and registers its
  # SMAppService/LaunchAgent supervisor on launch.
  app "__APP_NAME__.app"

  preflight do
    # An existing installation must settle and unregister through the product's
    # identity-verified daemonkit stop path before Homebrew replaces its bundle.
    # A present app with a missing or failing hook is a hard failure.
    installed_app = "#{appdir}/__APP_NAME__.app"
    if Dir.exist?(installed_app)
      system_command "#{installed_app}/Contents/MacOS/__BINARY_NAME__",
                     args: ["__STOP_UNINSTALL_ARG__"],
                     must_succeed: true
    end
  end

  postflight do
    # Strip Homebrew's download quarantine so first launch is silent
    # (notarized + stapled).
    system_command "/usr/bin/xattr",
                   args: ["-dr", "com.apple.quarantine", "#{appdir}/__APP_NAME__.app"],
                   must_succeed: false
    # Relaunch in the background (-g: no focus steal). Launching runs the app's
    # LoginItem.reconcile(), which (re)registers the supervisor.
    system_command "/usr/bin/open", args: ["-g", "#{appdir}/__APP_NAME__.app"], must_succeed: false
  end

  uninstall_preflight do
    # Boot the supervisor OUT before the app is quit/removed — quitting under a
    # live KeepAlive/SMAppService registration just triggers an instant relaunch.
    # The required product hook invokes AppKeepAlive.Stop (or the product's
    # equally exact stable-bundle service API), proves absence, then unregisters.
    system_command "#{appdir}/__APP_NAME__.app/Contents/MacOS/__BINARY_NAME__",
                   args: ["__STOP_UNINSTALL_ARG__"],
                   must_succeed: true
  end

  zap trash: [
    "~/Library/LaunchAgents/__LAUNCHAGENT_LABEL__.plist",
    "~/Library/Containers/__BUNDLE_ID__",
    "~/Library/Preferences/__BUNDLE_ID__.plist",
  ]
end
